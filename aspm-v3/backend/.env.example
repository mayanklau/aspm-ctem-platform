# ─── Server ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# Comma-separated allowlist of CORS origins. Use a real list in production.
# Examples: https://posture.yourbank.com,https://posture.staging.yourbank.com
CORS_ORIGINS=*

# JSON body size limit (default 2mb)
JSON_BODY_LIMIT=2mb

# ─── MySQL ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=aspm_db
DB_USER=root
DB_PASS=change-me

# Connection pool
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_POOL_ACQUIRE_MS=30000
DB_POOL_IDLE_MS=10000

# Set true for managed MySQL with TLS (RDS, Cloud SQL, etc.)
DB_SSL=false

# Log queries slower than this many ms (warn level)
DB_SLOW_QUERY_MS=500

# ─── Auth ───────────────────────────────────────────────────────────────────
# REQUIRED in production. Use a 32+ byte random string, e.g.
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=8h

# Force authentication on read endpoints too (default false)
REQUIRE_READ_AUTH=false

# ─── Rate limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
RATE_LIMIT_UPLOAD_MAX=30

# ─── Uploads ────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
UPLOAD_MAX_BYTES=52428800

# ─── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs

# ─── Oracle (optional, for PT/Compliance Oracle sync) ──────────────────────
ORACLE_USER=
ORACLE_PASS=
ORACLE_CONNECT=localhost:1521/ORCL
